<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GuitarStore Auth</title>
    <style>
        :root {
            color-scheme: light;
            --bg: #f3ede4;
            --panel: rgba(255, 252, 247, 0.9);
            --panel-edge: rgba(111, 85, 46, 0.14);
            --ink: #1f1a17;
            --muted: #65584f;
            --accent: #9a5f2c;
            --accent-strong: #774217;
            --danger: #9d2d2d;
            --shadow: 0 32px 80px rgba(71, 45, 20, 0.14);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Georgia, Cambria, "Times New Roman", serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(191, 133, 63, 0.22), transparent 34%),
                radial-gradient(circle at bottom right, rgba(96, 52, 23, 0.18), transparent 28%),
                linear-gradient(160deg, #f7f1e8 0%, #eadfce 48%, #f3ede4 100%);
            display: grid;
            place-items: center;
            padding: 24px;
        }

        .shell {
            width: min(100%, 960px);
            display: grid;
            grid-template-columns: minmax(0, 1.1fr) minmax(320px, 420px);
            border: 1px solid var(--panel-edge);
            border-radius: 28px;
            overflow: hidden;
            box-shadow: var(--shadow);
            background: var(--panel);
            backdrop-filter: blur(12px);
        }

        .hero {
            padding: 48px;
            background:
                linear-gradient(145deg, rgba(247, 232, 214, 0.95), rgba(234, 219, 198, 0.8)),
                repeating-linear-gradient(135deg, rgba(141, 96, 56, 0.05) 0, rgba(141, 96, 56, 0.05) 12px, transparent 12px, transparent 24px);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 32px;
        }

        .hero h1 {
            margin: 0;
            font-size: clamp(2rem, 4vw, 3.4rem);
            line-height: 0.98;
            letter-spacing: -0.04em;
        }

        .hero p,
        .hero li {
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.6;
        }

        .hero ul {
            margin: 0;
            padding-left: 18px;
        }

        .card {
            padding: 40px 34px;
            background: rgba(255, 254, 251, 0.96);
        }

        h2 {
            margin: 0 0 10px;
            font-size: 2rem;
            line-height: 1.05;
        }

        .intro {
            margin: 0 0 24px;
            color: var(--muted);
            line-height: 1.6;
        }

        .field {
            display: grid;
            gap: 8px;
            margin-bottom: 18px;
        }

        label {
            font-size: 0.95rem;
            font-weight: 700;
        }

        input[type=text],
        input[type=email],
        input[type=password] {
            width: 100%;
            border: 1px solid rgba(96, 72, 49, 0.18);
            border-radius: 14px;
            padding: 13px 14px;
            font-size: 1rem;
            font-family: inherit;
            background: rgba(255, 255, 255, 0.9);
        }

        input:focus {
            outline: 2px solid rgba(154, 95, 44, 0.18);
            border-color: rgba(154, 95, 44, 0.45);
        }

        .row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 22px;
            color: var(--muted);
        }

        .checkbox {
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .checkbox input {
            width: 16px;
            height: 16px;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 24px;
        }

        .button,
        button,
        a.button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 48px;
            padding: 0 18px;
            border-radius: 999px;
            border: 1px solid transparent;
            background: linear-gradient(135deg, var(--accent), var(--accent-strong));
            color: #fff9f3;
            text-decoration: none;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
        }

        .button.secondary {
            background: transparent;
            color: var(--accent-strong);
            border-color: rgba(154, 95, 44, 0.25);
        }

        .validation-summary-errors,
        .field-validation-error {
            color: var(--danger);
        }

        .validation-summary-errors ul {
            margin: 0 0 18px;
            padding-left: 18px;
        }

        .meta {
            font-size: 0.9rem;
            color: var(--muted);
        }

        @@media (max-width: 820px) {
            .shell {
                grid-template-columns: 1fr;
            }

            .hero,
            .card {
                padding: 28px;
            }
        }
    </style>
</head>
<body>
    <main class="shell">
        <section class="hero">
            <div>
                <div class="meta">GuitarStore Auth</div>
                <h1>Identity for the shop, not inside the SPA.</h1>
            </div>
            <div>
                <p>
                    This UI handles interactive sign-in for the OpenID Connect authorization flow.
                    API access stays on bearer tokens issued by OpenIddict.
                </p>
                <ul>
                    <li>Server-side login UI in ApiGateway</li>
                    <li>Identity cookie for browser session</li>
                    <li>Authorization Code + PKCE for the client app</li>
                </ul>
            </div>
        </section>
        <section class="card">
            @RenderBody()
        </section>
    </main>
</body>
</html>
