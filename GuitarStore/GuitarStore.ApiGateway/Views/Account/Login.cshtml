@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<h2>Sign in</h2>
<p class="intro">Use your GuitarStore account to continue the authorization flow.</p>

<form asp-action="Login" method="post">
    <div asp-validation-summary="ModelOnly"></div>
    <input asp-for="ReturnUrl" type="hidden" />

    <div class="field">
        <label asp-for="EmailOrUserName"></label>
        <input asp-for="EmailOrUserName" />
        <span asp-validation-for="EmailOrUserName"></span>
    </div>

    <div class="field">
        <label asp-for="Password"></label>
        <input asp-for="Password" />
        <span asp-validation-for="Password"></span>
    </div>

    <div class="row">
        <label class="checkbox">
            <input asp-for="RememberMe" />
            <span>Keep me signed in on this browser</span>
        </label>
    </div>

    <div class="actions">
        <button type="submit">Sign in</button>
        <a class="button secondary" asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">Create account</a>
        <a class="button secondary" asp-action="ForgotPassword">Forgot password</a>
    </div>
</form>
